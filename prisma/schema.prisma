generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String  @id @db.VarChar(36)
  name           String  @db.VarChar(50)
  username       String? @unique @db.VarChar(100)
  email          String? @unique @db.VarChar(100)
  password       String  @db.VarChar()
  imageUrl       String? @map("image_url") @db.VarChar()
  countFollower  Int     @default(0) @map("count_follower") @db.SmallInt
  countFollowing Int     @default(0) @map("count_following") @db.SmallInt

  createAt DateTime @default(now()) @map("create_at") @db.Timestamp()
  updateAt DateTime @updatedAt @map("update_at")

  followers UserFollows[] @relation("follower")
  following UserFollows[] @relation("following")

  tweets   Tweet[]
  like     Like[]

  @@map("user")
}

model Tweet {
  id        String @id @db.VarChar(36)
  content   String @db.VarChar()
  countLike Int    @default(0) @map("count_like") @db.SmallInt

  createAt DateTime @map("create_at") @db.Timestamp() @default(now())
  updateAt DateTime @updatedAt @map("update_at")

  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id") @db.VarChar(36)

  tweet ReplyTweet? @relation("tweet")
  reply ReplyTweet[] @relation("reply")

  userlike Like[]

  @@map("tweet")
}

model UserFollows {
  followerId  String @map("follower_id") @db.VarChar(36)
  followingId String @map("following_id") @db.VarChar(36)

  follower  User @relation("following", fields: [followerId], references: [id])
  following User @relation("follower", fields: [followingId], references: [id])

  @@id([followerId, followingId])
  @@map("user_follows")
}

model Like {
  userId  String  @map("user_id") @db.VarChar(36)
  tweetId String  @map("tweet_id") @db.VarChar(36)
  isLiked Boolean @default(false) @map("is_liked")

  user  User  @relation(fields: [userId], references: [id])
  tweet Tweet @relation(fields: [tweetId], references: [id])

  @@id([userId, tweetId])
  @@map("like")
}

model ReplyTweet {
  tweetId  String @map("tweet_id") @db.VarChar(36) @unique
  replyId String @map("reply_id") @db.VarChar(36)

  tweet  Tweet @relation("tweet", fields: [tweetId], references: [id])
  reply Tweet @relation("reply", fields: [replyId], references: [id])

  @@id([tweetId, replyId])
  @@map("reply_tweet")
}
