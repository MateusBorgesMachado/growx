
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @db.VarChar(36) @default(uuid())
  name String @db.VarChar(50)
  username String? @db.VarChar(100) @unique 
  email String? @db.VarChar(100) @unique
  imageUrl String? @db.VarChar() @map("image_url")

  createAt DateTime @db.Timestamp() @map("create_at")
  updateAt DateTime @updatedAt @map("update_at")

  followers UserFollows[] @relation("follower")
  following UserFollows[] @relation("following")

  tweets Tweet[]

  @@map("user")
}

model Tweet {
  id String @id @db.VarChar(36) @default(uuid())
  content String @db.VarChar()

  createAt DateTime @db.Timestamp() @map("create_at")
  updateAt DateTime @updatedAt @map("update_at")

  user User @relation(fields: [userId], references: [id])
  userId String @db.VarChar(36)


  @@map("tweet")
}

model UserFollows {
  followerId String @db.VarChar(36)
  followingId String @db.VarChar(36)

  follower User @relation("follower", fields: [followerId], references: [id])
  following User @relation("following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}