generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String  @id @default(uuid()) @db.VarChar(36)
  name           String  @db.VarChar(50)
  username       String? @unique @db.VarChar(100)
  email          String? @unique @db.VarChar(100)
  password       String  @db.VarChar()
  imageUrl       String? @map("image_url") @db.VarChar()
  countFollower  Int     @map("count_follower") @db.SmallInt
  countFollowing Int     @map("count_following") @db.SmallInt

  createAt DateTime @map("create_at") @db.Timestamp()
  updateAt DateTime @updatedAt @map("update_at")

  followers UserFollows[] @relation("follower")
  following UserFollows[] @relation("following")

  tweets Tweet[]
  like Like[]

  @@map("user")
}

model Tweet {
  id      String @id @default(uuid()) @db.VarChar(36)
  content String @db.VarChar()
  countLike    Int    @db.SmallInt
  countDislike Int    @db.SmallInt

  createAt DateTime @map("create_at") @db.Timestamp()
  updateAt DateTime @updatedAt @map("update_at")

  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id") @db.VarChar(36)

  userlike Like[]

  @@map("tweet")
}

model UserFollows {
  followerId  String @map("follower_id") @db.VarChar(36)
  followingId String @map("following_id") @db.VarChar(36)

  follower  User @relation("follower", fields: [followerId], references: [id])
  following User @relation("following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
  @@map("user_follows")
}

model Like {
  userId String @map("user_id") @db.VarChar(36)
  tweetId String @map("tweet_id") @db.VarChar(36)
  isLiked Boolean @map("is_liked") @default(false)

  user User @relation(fields: [userId], references: [id])
  tweet Tweet @relation(fields: [tweetId], references: [id])

  @@id([userId, tweetId])
  @@map("like")
}
